{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "scripts/**/*",
    "design-system/**/*",
    "*.js",
    "*.mjs"
  ],
  "exclude": ["node_modules", "dist"]
}
